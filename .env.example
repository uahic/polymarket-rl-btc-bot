# Polymarket Trading Bot Environment Variables
# Copy this file to .env and fill in your values
# Load with: source .env or use python-dotenv

# =============================================================================
# Required: Wallet Configuration
# =============================================================================

# Your MetaMask private key (64 hex characters, with or without 0x prefix)
# WARNING: Never commit this to git!
POLY_PRIVATE_KEY=

# Your Polymarket Safe/Proxy wallet address
# Find at: polymarket.com/settings -> General -> Wallet Address
POLY_SAFE_ADDRESS=

# =============================================================================
# Required for Gasless Trading: Builder Program Credentials
# =============================================================================

# Apply for Builder Program at: polymarket.com/settings?tab=builder
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=